# Git
.git
.gitignore

# Local Python venv — Docker builds its own in the image
.venv/

# Environment / secrets — injected at runtime, not baked in
.env
.env.*
!.env.example

# Node dev artifacts
node_modules
npm-debug.log
coverage
.nyc_output

# Uploads — temp files, not app source
uploads/*
!uploads/.gitkeep

# Model caches — NLLB-200 is mounted as a volume at runtime
.hf_cache/

# Python bytecode
__pycache__
*.pyc
*.pyo

# Docs and IDE
*.md
!README.md
.vscode
.idea
.DS_Store
Thumbs.db

# Test files
test
tests

